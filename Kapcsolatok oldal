<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kapcsolatok</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f5f5f5;
            font-family: Arial, sans-serif;
        }

        .hero {
            background: linear-gradient(to right, #111, #333);
            color: white;
            padding: 60px 20px;
            text-align: center;
        }

        .contact-box {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        footer {
            background: #111;
            color: white;
            text-align: center;
            padding: 15px;
            margin-top: 50px;
        }
    </style>
</head>
<body>

    <!-- Navigáció -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">KKicks</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#">Főoldal</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Cipők</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="#">Kapcsolatok</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Fejléc -->
    <section class="hero">
        <h1>Kapcsolatok</h1>
        <p>Lépj kapcsolatba velünk bármikor!</p>
    </section>

    <!-- Tartalom -->
    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="contact-box">

                    <h2 class="mb-4 text-center">Elérhetőségeink</h2>

                    <div class="mb-3">
                        <h5>Email</h5>
                        <p>info@kkicks.hu</p>
                    </div>

                    <div class="mb-3">
                        <h5>Telefonszám</h5>
                        <p>+36 30 123 4567</p>
                    </div>

                    <div class="mb-4">
                        <h5>Cím</h5>
                        <p>Miskolc, Magyarország</p>
                    </div>

                    <!-- Űrlap -->
                    <form>
                        <div class="mb-3">
                            <label class="form-label">Név</label>
                            <input type="text" class="form-control" placeholder="Add meg a neved">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email cím</label>
                            <input type="email" class="form-control" placeholder="pelda@email.com">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Üzenet</label>
                            <textarea class="form-control" rows="5" placeholder="Írd ide az üzeneted"></textarea>
                        </div>

                        <button type="submit" class="btn btn-dark w-100">
                            Küldés
                        </button>
                    </form>

                </div>
            </div>
        </div>
    </div>

    <!-- Lábléc -->
    <footer>
        <p>© 2026 KKicks - Minden jog fenntartva.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
